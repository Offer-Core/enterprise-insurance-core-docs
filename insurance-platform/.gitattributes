*.scss text diff=css
*.sass text diff=css
*.less text diff=css
*.xml text diff=xml
*.xsd text diff=xml
*.xsl text diff=xml
*.xslt text diff=xml
*.yaml text
*.yml text
*.json text
*.properties text
