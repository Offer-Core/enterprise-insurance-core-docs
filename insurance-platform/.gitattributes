# Auto detect text files and perform LF normalization
* text=auto

# Source code
*.java text diff=java
*.kt text diff=kotlin
*.kts text diff=kotlin
*.groovy text diff=groovy
*.js text diff=javascript
*.ts text diff=typescript
*.jsx text diff=javascript
*.tsx text diff=typescript
*.html text diff=html
