root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{java,kt,kts}]
indent_style = space
indent_size = 4
tab_width = 4

[*.{xml,xsd,xsl,xslt}]
indent_style = space
indent_size = 2
tab_width = 2

[*.{yaml,yml}]
indent_style = space
indent_size = 2
tab_width = 2

[*.{js,ts,jsx,tsx}]
indent_style = space
indent_size = 2
tab_width = 2

[*.json]
indent_style = space
indent_size = 2
tab_width = 2

[*.{css,scss,sass,less}]
indent_style = space
indent_size = 2
tab_width = 2

[*.{md,markdown}]
indent_style = space
indent_size = 4
trim_trailing_whitespace = false
insert_final_newline = true

[*.properties]
indent_style = space
indent_size = 4
tab_width = 4

[*.sh]
indent_style = space
indent_size = 4
tab_width = 4

[*.{py,rb,go}]
indent_style = space
indent_size = 4
tab_width = 4

[*.sql]
indent_style = space
indent_size = 2
tab_width = 2

[Dockerfile]
indent_style = space
indent_size = 4

[Makefile]
indent_style = tab
indent_size = 4
tab_width = 4

